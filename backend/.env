LANGCHAIN_API_KEY=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
LANGCHAIN_PROJECT=selfhealrag

# ------- App Settings -------
LOG_LEVEL=INFO
ENVIRONMENT=development
APP_NAME=Self-Healing RAG
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ------- Security -------
SECRET_KEY=imshiva
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------- RAG Config -------
# Retrieval
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
MULTI_QUERY_COUNT=3
CONTEXT_SCORE_THRESHOLD=0.70
